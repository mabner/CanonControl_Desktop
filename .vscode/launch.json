{
    "version": "0.2.0",
    "configurations": [
      {
        "name": "CanonControl (Debug Raspberry GUI)",
        "type": "coreclr",
        "request": "launch",
  
        "program": "${workspaceFolder}/bin/Debug/net10.0/CanonControl.dll",
        "cwd": "${workspaceFolder}",
  
        "console": "integratedTerminal",
  
        "stopAtEntry": false,
  
        "env": {
          "DISPLAY": ":0",
          "DOTNET_EnableDiagnostics": "1"
        },
  
        "preLaunchTask": "prepare-run"
      }
    ]
  }