<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:CanonControl.ViewModels"
             x:Class="CanonControl.Views.SettingsView"
             x:DataType="vm:SettingsViewModel">
        <StackPanel Spacing="16" Margin="16">
                <!-- Save Path -->
                <TextBlock Text="Save Path" FontWeight="Bold" />
                <Grid ColumnDefinitions="*,Auto">
                        <TextBox Grid.Column="0"
                                 Text="{Binding SavePath}"
                                 IsEnabled="{Binding HasHostSaveDestination}"
                                 PlaceholderText="Enter save path..."
                                 MinHeight="44" />
                        <Button Grid.Column="1"
                                Content="Browse"
                                Command="{Binding BrowseSavePathCommand}"
                                IsEnabled="{Binding HasHostSaveDestination}"
                                MinWidth="80" MinHeight="44"
                                Margin="4,0,0,0" />
                </Grid>

                <!-- Save Destination -->
                <TextBlock Text="Save Images To" FontWeight="Bold" />
                <ComboBox ItemsSource="{Binding SaveDestinationOptions}"
                          SelectedIndex="{Binding SaveDestinationIndex}"
                          MinHeight="44"
                          HorizontalAlignment="Stretch"
                          ToolTip.Tip="Camera only: saves to memory card (no PC download). PC only: downloads to PC, nothing on card. Camera + PC: saves to card and downloads to PC." />

                <!-- Live View Frame Rate -->
                <TextBlock Text="Live View Frame Rate (fps)" FontWeight="Bold" />
                <ComboBox ItemsSource="{Binding FrameRateOptions}"
                          SelectedItem="{Binding LiveViewFrameRate}"
                          MinHeight="44"
                          HorizontalAlignment="Stretch" />

                <!-- Live View During Auto Focus -->
                <CheckBox Content="Live View During Auto Focus"
                          IsChecked="{Binding LiveViewDuringAutoFocus}"
                          MinHeight="44"
                          ToolTip.Tip="Enable real-time preview during autofocus. Disable if you experience stability issues." />

                <!-- Connection Timeout -->
                <TextBlock Text="Connection Timeout (seconds)" FontWeight="Bold" />
                <ComboBox ItemsSource="{Binding ConnectionTimeoutOptions}"
                          SelectedItem="{Binding ConnectionTimeout}"
                          MinHeight="44"
                          HorizontalAlignment="Stretch"
                          ToolTip.Tip="How long to wait when searching for a camera connection" />

                <!-- Focus Steps -->
                <TextBlock Text="Focus Medium Steps" FontWeight="Bold" />
                <ComboBox ItemsSource="{Binding FocusStepOptions}"
                          SelectedItem="{Binding FocusMediumSteps}"
                          MinHeight="44"
                          HorizontalAlignment="Stretch"
                          ToolTip.Tip="Number of fine steps to send per Medium focus trigger" />
                <TextBlock Text="Focus Coarse Steps" FontWeight="Bold" />
                <ComboBox ItemsSource="{Binding FocusStepOptions}"
                          SelectedItem="{Binding FocusCoarseSteps}"
                          MinHeight="44"
                          HorizontalAlignment="Stretch"
                          ToolTip.Tip="Number of fine steps to send per Coarse focus trigger" />

                <!-- Camera Card Folder Selection -->
                <TextBlock Text="Camera Card Folder" FontWeight="Bold" />
                <Grid ColumnDefinitions="*,Auto,Auto">
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding AvailableFolders}"
                                  SelectedIndex="{Binding SelectedFolderIndex}"
                                  MinHeight="44"
                                  HorizontalAlignment="Stretch"
                                  ToolTip.Tip="Select where to save images on the camera's memory card" />
                        <Button Grid.Column="1"
                                Content="Refresh"
                                Command="{Binding RefreshCameraFoldersListCommand}"
                                MinWidth="80" MinHeight="44"
                                Margin="4,0,0,0"
                                ToolTip.Tip="Refresh folder list from camera" />
                        <Button Grid.Column="2"
                                Content="Create"
                                Command="{Binding CreateNewCameraFolderCommand}"
                                MinWidth="80" MinHeight="44"
                                Margin="4,0,0,0"
                                ToolTip.Tip="Create a new folder on camera memory card" />
                </Grid>

                <!-- Status -->
                <TextBlock Text="{Binding Status}"
                           FontSize="12"
                           Foreground="Red"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />

                <!-- Save Button -->
                <Button Content="Save Settings"
                        Command="{Binding SaveSettingsCommand}"
                        MinWidth="120" MinHeight="44"
                        HorizontalAlignment="Center"
                        Margin="0,16,0,0" />

                <!-- Info Text -->
                <TextBlock Text="Settings are saved automatically when you click Save."
                           FontSize="12"
                           Foreground="Gray"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center" />

                <!-- Settings File Path -->
                <TextBlock Text="{Binding SettingsFilePath, StringFormat='Settings file: {0}'}"
                           FontSize="10"
                           Foreground="DarkGray"
                           TextWrapping="Wrap"
                           HorizontalAlignment="Center"
                           Margin="0,8,0,0" />
        </StackPanel>
</UserControl>
