<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:CanonControl.ViewModels"
             xmlns:helpers="using:CanonControl.Helpers"
             x:Class="CanonControl.Views.RemoteCaptureView"
             x:DataType="vm:RemoteCaptureViewModel">

        <UserControl.Resources>
                <helpers:GreaterThanZeroConverter x:Key="GreaterThanZeroConverter" />
        </UserControl.Resources>

        <StackPanel Spacing="16" Margin="16">

                <!-- Camera Settings Display -->
                <TextBlock Text="Camera Settings" FontSize="18" FontWeight="Bold" />
                <StackPanel Spacing="12">

                        <!-- Shutter Speed -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Speed:" Width="80" VerticalAlignment="Center" />
                                <Button Content="-"
                                        Command="{Binding DecrementShutterSpeedCommand}"
                                        MinWidth="44" MinHeight="44"
                                        Padding="0" />
                                <TextBlock Text="{Binding ShutterSpeed, FallbackValue='--'}"
                                           VerticalAlignment="Center"
                                           MinWidth="80"
                                           TextAlignment="Center" />
                                <Button Content="+"
                                        Command="{Binding IncrementShutterSpeedCommand}"
                                        MinWidth="44" MinHeight="44"
                                        Padding="0" />
                        </StackPanel>

                        <!-- Aperture -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="Aperture:" Width="80" VerticalAlignment="Center" />
                                <Button Content="-"
                                        Command="{Binding DecrementApertureCommand}"
                                        MinWidth="44" MinHeight="44"
                                        Padding="0" />
                                <TextBlock Text="{Binding Aperture, FallbackValue='--'}"
                                           VerticalAlignment="Center"
                                           MinWidth="80"
                                           TextAlignment="Center" />
                                <Button Content="+"
                                        Command="{Binding IncrementApertureCommand}"
                                        MinWidth="44" MinHeight="44"
                                        Padding="0" />
                        </StackPanel>

                        <!-- ISO -->
                        <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="ISO:" Width="80" VerticalAlignment="Center" />
                                <Button Content="-"
                                        Command="{Binding DecrementIsoCommand}"
                                        MinWidth="44" MinHeight="44"
                                        Padding="0" />
                                <StackPanel Orientation="Vertical" VerticalAlignment="Center" MinWidth="80">
                                        <TextBlock Text="{Binding Iso, FallbackValue='--'}"
                                                   TextAlignment="Center" />
                                        <TextBlock Text="(actual in EXIF)"
                                                   FontSize="10"
                                                   Foreground="Gray"
                                                   TextAlignment="Center"
                                                   IsVisible="{Binding IsAutoIso}" />
                                </StackPanel>
                                <Button Content="+"
                                        Command="{Binding IncrementIsoCommand}"
                                        MinWidth="44" MinHeight="44"
                                        Padding="0" />
                        </StackPanel>
                </StackPanel>

                <!-- Delay Timer Selection -->
                <TextBlock Text="Capture Delay" FontSize="18" FontWeight="Bold" Margin="0,16,0,0" />
                <ComboBox SelectedIndex="{Binding DelaySecondsIndex}"
                          MinHeight="44"
                          MinWidth="200">
                        <ComboBoxItem Content="No delay" />
                        <ComboBoxItem Content="2 seconds" />
                        <ComboBoxItem Content="5 seconds" />
                        <ComboBoxItem Content="10 seconds" />
                </ComboBox>

                <!-- Histogram Display Mode -->
                <TextBlock Text="Histogram Display" FontSize="18" FontWeight="Bold" Margin="0,16,0,0" />
                <ComboBox SelectedIndex="{Binding HistogramModeIndex}"
                          MinHeight="44"
                          MinWidth="200">
                        <ComboBoxItem Content="None" />
                        <ComboBoxItem Content="Luminance" />
                        <ComboBoxItem Content="RGB" />
                </ComboBox>

                <!-- Composition Aid Mode -->
                <TextBlock Text="Composition Aid" FontSize="18" FontWeight="Bold" Margin="0,16,0,0" />
                <StackPanel Orientation="Horizontal" Spacing="8">
                        <ComboBox SelectedIndex="{Binding CompositionModeIndex}"
                                  MinHeight="44"
                                  MinWidth="200">
                                <ComboBoxItem Content="None" />
                                <ComboBoxItem Content="Rule of Thirds" />
                                <ComboBoxItem Content="Golden Ratio" />
                                <ComboBoxItem Content="Golden Triangle" />
                                <ComboBoxItem Content="Center Cross" />
                                <ComboBoxItem Content="Diagonal Lines" />
                                <ComboBoxItem Content="Grid" />
                        </ComboBox>

                        <!-- Golden Ratio/Triangle controls - only visible when Golden Ratio or Golden Triangle is selected -->
                        <Button Content="↔️"
                                ToolTip.Tip="Mirror"
                                Command="{Binding ToggleCompositionMirrorCommand}"
                                MinWidth="44" MinHeight="44"
                                IsVisible="{Binding IsGoldenCompositionMode}" />

                        <!-- Rotate button only for Golden Ratio (not for Golden Triangle) -->
                        <Button Content="↻"
                                ToolTip.Tip="Rotate 90°"
                                Command="{Binding RotateCompositionCommand}"
                                MinWidth="44" MinHeight="44"
                                IsVisible="{Binding CompositionMode, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=GoldenRatio}" />
                </StackPanel>

                <!-- Countdown Display -->
                <TextBlock Text="{Binding CountdownSeconds, StringFormat='Capturing in {0}...'}"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="Orange"
                           HorizontalAlignment="Center"
                           Margin="0,16,0,0"
                           IsVisible="{Binding CountdownSeconds, Converter={StaticResource GreaterThanZeroConverter}}" />
        </StackPanel>
</UserControl>
