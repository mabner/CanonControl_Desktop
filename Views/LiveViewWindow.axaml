<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:CanonControl.ViewModels"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
        Width="800" Height="450"
        x:Class="CanonControl.Views.LiveViewWindow"
        x:DataType="vm:LiveViewViewModel"
        Title="Live View">
  <Grid RowDefinitions="*,Auto,*" Margin="10">
    <Border Grid.Row="0" Background="Black">
      <Image Source="{Binding LiveImage}" PointerPressed="OnImageClick" Stretch="Uniform" />
    </Border>
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="6">
      <Button Content="Start" Width="80" Height="60"
              Command="{Binding StartLiveViewCommand}" />
      <Button Content="Stop" Width="80" Height="60"
              Command="{Binding StopLiveViewCommand}" />
      <Button Content="Back" Width="80" Height="60"
              Click="OnBackClick" />
    </StackPanel>
    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="6">
      <Button Content="&lt;&lt;" Width="80" Height="60"
              Command="{Binding FocusNearCommand}" />
      <Button Content="AF" Width="80" Height="60"
              Command="{Binding AutoFocusCommand}" />
      <Button Content="&gt;&gt;" Width="80" Height="60"
              Command="{Binding FocusFarCommand}" />
      <Button Content="SHOT" Width="100" Height="60"
              Command="{Binding TakePictureCommand}" />
    </StackPanel>
  </Grid>
</Window>
