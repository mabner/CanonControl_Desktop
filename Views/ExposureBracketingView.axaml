<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
             xmlns:vm="using:CanonControl.ViewModels"
             x:Class="CanonControl.Views.ExposureBracketingView"
             x:DataType="vm:ExposureBracketingViewModel">

  <StackPanel Spacing="16" Margin="16">
    <TextBlock Text="Exposure Bracketing"
               FontSize="20"
               FontWeight="Bold"
               Margin="0,0,0,8" />

    <!-- Exposure Parameter Selection -->
    <StackPanel Spacing="8">
      <TextBlock Text="Adjust Parameter:" FontSize="16" />
      <ComboBox SelectedIndex="{Binding ExposureParameterIndex}"
                MinWidth="200"
                MinHeight="44"
                IsEnabled="{Binding !IsRunning}">
        <ComboBoxItem Content="Shutter Speed" />
        <ComboBoxItem Content="ISO" />
      </ComboBox>
      <TextBlock Text="Which setting to change for bracketing"
                 FontSize="12"
                 Foreground="Gray" />
    </StackPanel>

    <!-- Number of Shots -->
    <StackPanel Spacing="8">
      <TextBlock Text="Number of Shots:" FontSize="16" />
      <NumericUpDown Value="{Binding NumberOfShots}"
                     Minimum="3"
                     Maximum="9"
                     Increment="2"
                     FormatString="0"
                     MinWidth="200"
                     MinHeight="44"
                     IsEnabled="{Binding !IsRunning}" />
      <TextBlock Text="Must be an odd number (3, 5, 7, 9)"
                 FontSize="12"
                 Foreground="Gray" />
    </StackPanel>

    <!-- Step Size -->
    <StackPanel Spacing="8">
      <TextBlock Text="Step Size (EV):" FontSize="16" />
      <ComboBox SelectedIndex="{Binding StepSizeIndex}"
                MinWidth="200"
                MinHeight="44"
                IsEnabled="{Binding !IsRunning}">
        <ComboBoxItem Content="1/3 stop" />
        <ComboBoxItem Content="1/2 stop" />
        <ComboBoxItem Content="2/3 stop" />
        <ComboBoxItem Content="1 stop" />
        <ComboBoxItem Content="1.5 stops" />
        <ComboBoxItem Content="2 stops" />
        <ComboBoxItem Content="3 stops" />
      </ComboBox>
      <TextBlock Text="Exposure change between shots"
                 FontSize="12"
                 Foreground="Gray" />
    </StackPanel>

    <!-- Status -->
    <StackPanel Spacing="8">
      <TextBlock Text="Status:" FontSize="16" />
      <TextBlock Text="{Binding Status}"
                 FontSize="14"
                 Foreground="{Binding IsRunning, Converter={StaticResource BoolToColorConverter}}" />
      <TextBlock Text="{Binding CurrentShot, StringFormat='Current Shot: {0}'}"
                 FontSize="14"
                 IsVisible="{Binding IsRunning}" />
    </StackPanel>

    <!-- Info -->
    <Border Background="#F0F0F0"
            Padding="12"
            CornerRadius="4"
            Margin="0,8,0,0">
      <StackPanel Spacing="4">
        <TextBlock Text="How it works:"
                   FontWeight="Bold"
                   FontSize="14" />
        <TextBlock Text="• Takes multiple shots with different exposures"
                   FontSize="12"
                   TextWrapping="Wrap" />
        <TextBlock Text="• Middle shot uses current camera settings"
                   FontSize="12"
                   TextWrapping="Wrap" />
        <TextBlock Text="• Other shots are darker/brighter by step size"
                   FontSize="12"
                   TextWrapping="Wrap" />
        <TextBlock Text="• Useful for HDR photography"
                   FontSize="12"
                   TextWrapping="Wrap" />
      </StackPanel>
    </Border>
  </StackPanel>

</UserControl>
