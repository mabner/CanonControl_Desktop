<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:helpers="using:CanonControl.Helpers"
             x:Class="CanonControl.App"
             xmlns:local="using:CanonControl"
             RequestedThemeVariant="Default">
    <!-- "Default" ThemeVariant follows system theme variant. "Dark" or "Light" are other available options. -->

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Styles>
        <FluentTheme />

        <Style Selector="TextBlock">
            <Setter Property="FontSize" Value="18" />
        </Style>

        <Style Selector="Button">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="MinWidth" Value="80" />
            <Setter Property="MinHeight" Value="50" />
        </Style>

        <Style Selector="Button.accent">
            <Setter Property="Background" Value="#3784FF" />
            <Setter Property="Foreground" Value="White" />
        </Style>

        <Style Selector="Button > TextBlock">
            <Setter Property="FontSize" Value="14" />
        </Style>
    </Application.Styles>

    <Application.Resources>
        <helpers:BoolToColorConverter x:Key="BoolToColorConverter" />
        <helpers:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <helpers:EnumNotEqualConverter x:Key="EnumNotEqualConverter" />
    </Application.Resources>
</Application>